# 複製這個檔成 .env，把值填進去（雲端則填在平台的 Environment 設定）

# LINE Developers > Messaging API channel
LINE_CHANNEL_ACCESS_TOKEN=你的_channel_access_token
LINE_CHANNEL_SECRET=你的_channel_secret

# Anthropic（Claude）API 金鑰： https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 選填：模型（預設 haiku，便宜快速；要更聰明可改 claude-sonnet-4-6）
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# 選填：你自己的 LINE userId，填了之後每次「轉人工」會推播通知你
# 取得方式：先部署好，自己用 LINE 傳一句話給機器人，看雲端 log 印出的「收到 <你的ID>」
OWNER_USER_ID=

# 本機測試用的埠（雲端會自動帶入，不用管）
PORT=3000
